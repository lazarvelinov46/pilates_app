rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------- HELPERS ----------------
    function isSignedIn() {
      return request.auth != null;
    }

    // True when the authenticated user is the owner of the document (uid match).
    // Named isDocOwner to avoid collision with the 'owner' role concept below.
    function isDocOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function _callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && _callerRole() == 'admin';
    }

    function isOwnerRole() {
      return isSignedIn() && _callerRole() == 'owner';
    }

    // Owner role has all admin privileges plus extras.
    function isAdminOrOwner() {
      return isSignedIn() && _callerRole() in ['admin', 'owner'];
    }

    // ---------------- USERS ----------------
    match /users/{userId} {
      allow read, create, update: if isDocOwner(userId);
      allow read, update:         if isAdminOrOwner();
      allow list:                 if isAdminOrOwner();
      allow delete:               if isDocOwner(userId);

      // ── Notifications subcollection ──────────────────────────────────────
      match /notifications/{notificationId} {
        allow read, create: if isDocOwner(userId);
        allow update:       if isDocOwner(userId);
        allow delete:       if isDocOwner(userId);
      }
    }

    // ---------------- SESSIONS ----------------
    match /sessions/{sessionId} {
      allow read:          if isSignedIn();
      allow create:        if isAdminOrOwner();
      allow delete:        if isAdminOrOwner();
      allow update:        if isSignedIn();
    }

    // ---------------- BOOKINGS ----------------
    match /bookings/{bookingId} {
      allow get:    if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read:   if isAdminOrOwner();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // User cancelling their own booking
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.status == 'cancelled';

      // User stamping attendanceRecorded on their own past booking
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['attendanceRecorded']);

      // Admin or owner can update any booking
      allow update: if isAdminOrOwner();

      allow delete: if false;
    }

    // ---------------- DELETED ACCOUNTS ----------------
    // Stores a minimal tombstone {email, trialSessionUsed, deletedAt} so that
    // the free-trial restriction carries over if a user re-registers after
    // deleting their account. The document ID is the lowercased email address.
    // Only a signed-in user may write their own tombstone; reads are denied
    // (the check on re-registration is done server-side via the Auth SDK).
    match /deleted_accounts/{email} {
      allow read, create, update: if isSignedIn()
        && request.auth.token.email.lower() == email;
      allow delete: if false;
    }

    // ---------------- PACKAGES ----------------
    // Only the owner role may modify packages; admins (and users) are read-only.
    match /packages/{packageId} {
      allow read:                    if isSignedIn();
      allow create, update, delete:  if isOwnerRole();
    }

    // ---------------- RATINGS ----------------
    match /ratings/{ratingId} {
      allow read: if isAdminOrOwner() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------------- PROMOTION ASSIGNMENTS ----------------
    // Written whenever admin or owner assigns a promotion to a user.
    // Only the owner role can read them (the Assignments screen).
    match /promotion_assignments/{assignmentId} {
      allow read:          if isOwnerRole();
      allow create:        if isAdminOrOwner();
      allow update, delete: if false;
    }
  }
}
